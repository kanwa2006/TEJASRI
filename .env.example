# TEJASRI environment configuration
# Copy to .env and fill in values. NEVER commit .env.

# --- Application ---
TEJASRI_ENV=development            # development | test | production
TEJASRI_LOG_LEVEL=INFO

# --- Database (CockroachDB) ---
# The app must connect as the least-privilege user, never as root/admin
# (admin bypasses Row-Level Security — see docs/adr/0006). Provision with:
#   python -m tejasri.cli migrate && python -m tejasri.cli create-app-user
DATABASE_URL=postgresql://tejasri_app@localhost:26257/defaultdb?sslmode=disable
# CockroachDB Cloud (Basic): postgresql://<app-user>:<pass>@<host>:26257/tejasri?sslmode=verify-full

# --- LLM providers ---
LLM_PROVIDER=gemini                # gemini | ollama | bedrock
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
# AWS credentials for Bedrock/Lambda/S3 come from the standard AWS env/credential chain.

# --- Auth ---
JWT_SECRET_KEY=change-me-generate-a-long-random-string
JWT_ACCESS_TOKEN_MINUTES=30

# --- AWS ---
AWS_REGION=ap-south-1
S3_BUCKET=
